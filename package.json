{
  "name": "wemusic",
  "version": "1.0.0",
  "description": "本地部署的个人音乐网站：QQ音乐歌单/歌手解析 + Bilibili 免费播放",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "concurrently \"nodemon server/index.js\" \"vite build --watch\"",
    "dev": "concurrently \"nodemon server/index.js\" \"vite build --watch\"",
    "dev:watch": "node scripts/codegraph.js && concurrently \"nodemon server/index.js\" \"vite build --watch\"",
    "init-db": "node server/db.js",
    "build": "node scripts/codegraph.js && vite build",
    "build:watch": "vite build --watch",
    "dev:full": "concurrently \"nodemon server/index.js\" \"vite build --watch\"",
    "deploy": "node scripts/codegraph.js && node scripts/build-restart.js",
    "verify": "npm test",
    "mobile": "node scripts/mobile-open.js",
    "webhook": "node server/webhook.js",
    "test": "vitest run && node scripts/check-deps.js",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit/",
    "test:api": "vitest run tests/api/",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "e2e": "node scripts/e2e.js",
    "check-deps": "node scripts/check-deps.js",
    "codegraph": "node scripts/codegraph.js"
  },
  "keywords": [
    "music",
    "qqmusic",
    "bilibili",
    "personal",
    "local"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "puppeteer": "^24.43.1"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.3",
    "dependency-cruiser": "^16.10.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
