{
  "name": "wemusic",
  "version": "1.0.0",
  "description": "本地部署的个人音乐网站：QQ音乐歌单/歌手解析 + Bilibili 免费播放",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node --watch server/index.js",
    "dev": "node --watch server/index.js",
    "dev:watch": "node --watch server/index.js & vite build --watch",
    "init-db": "node server/db.js",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev:full": "concurrently \"node --watch server/index.js\" \"vite build --watch\"",
    "deploy": "node scripts/build-restart.js",
    "verify": "node scripts/verify.js",
    "mobile": "node scripts/mobile-open.js",
    "webhook": "node server/webhook.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:api": "vitest run tests/api/",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e"
  },
  "keywords": [
    "music",
    "qqmusic",
    "bilibili",
    "personal",
    "local"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "puppeteer": "^24.43.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "supertest": "^7.2.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
