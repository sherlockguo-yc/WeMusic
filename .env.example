# 服务监听端口
PORT=5174

# JWT 签名密钥（请改为随机字符串）
JWT_SECRET=please-change-this-to-a-random-secret

# 是否允许注册新用户（本地单用户场景，注册一次后可设为 false 关闭注册）
ALLOW_REGISTER=true

# 管理员用户名（设置为自己的用户名，用逗号分隔多人：admin1,admin2）
ADMIN_USERNAME=

# GitHub Webhook 签名密钥（需要与 GitHub 仓库 webhook 设置中的 Secret 一致）
# 生成方法：openssl rand -hex 32
WEBHOOK_SECRET=
